<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tvDeliverLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deliver to"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvAdress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Home - 123, Ocean Street, Mumbai - 400001"
        android:textSize="15sp"
        android:maxLines="1"
        android:textStyle="bold"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@+id/tvDeliverLable"
        app:layout_constraintStart_toStartOf="@id/tvDeliverLable"
        android:layout_marginEnd="16dp"/>
    <ImageView
        android:id="@+id/LocationPin"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/location"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/tvDeliverLable"
        app:layout_constraintBottom_toBottomOf="@id/tvAdress"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="40dp"
        android:hint="Search for products..."
        android:paddingHorizontal="16dp"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvAdress"
        tools:layout_editor_absoluteX="25dp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBanner"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:background="#FFD454"
        app:layout_constraintTop_toBottomOf="@id/etSearch">

        <TextView
            android:id="@+id/tvFreeDelivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Free Delivery"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="on orders above ₹199"
            android:textColor="@color/text_black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tvFreeDelivery"
            app:layout_constraintStart_toStartOf="@id/tvFreeDelivery" />

        <ImageView
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="16dp"
            android:src="@drawable/blinkit"
            app:layout_constraintEnd_toEndOf="parent"
            tools:layout_editor_absoluteY="16dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvAllProducts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All Products"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="18dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/clBanner"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- The Product List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAllProducts"
        app:layout_constraintBottom_toBottomOf="parent" />



</androidx.constraintlayout.widget.ConstraintLayout>