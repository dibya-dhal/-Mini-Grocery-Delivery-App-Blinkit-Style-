<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btnBlack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        />
    <TextView
        android:id="@+id/verifySub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify OTP"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnBlack"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/tvVerifySub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter the 4-digit OTP sent to\n+91 98765 43210"
        android:textSize="19sp"
        android:textColor="@color/text_gray"
        android:textStyle="bold"
        android:layout_marginTop="29dp"
        app:layout_constraintTop_toBottomOf="@id/verifySub"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llOtpInputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvVerifySub">

        <EditText
            android:id="@+id/etOtp1"
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="1"
            android:layout_margin="8dp"/>

        <EditText
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="2"
            android:layout_margin="8dp"/>

        <EditText
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="3"
            android:layout_margin="8dp"/>


        <EditText
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="4"
            android:layout_margin="8dp"/>



    </LinearLayout>

    <TextView
        android:id="@+id/tvResend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Didn't receive OTP? Resend in 00.25"
        android:textSize="19sp"
        android:layout_marginTop="45dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/llOtpInputs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Verify &amp; Continue"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_blue"
        android:textColor="@color/white"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toBottomOf="@id/tvResend" />



    <!-- Fake OTP Demo Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/light_gray"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="For demo purpose use"
        android:textSize="18sp"
        android:gravity="center"
        android:textColor="@color/text_gray" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fake OTP: 1234"
            android:textSize="25sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/text_black" />
    </LinearLayout>










</androidx.constraintlayout.widget.ConstraintLayout>