<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp">
    <ImageView
        android:id="@+id/ivLoginHeader"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:src="@drawable/blinkit"
        android:scaleType="centerInside"
        android:layout_marginTop="70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        />

    <TextView
        android:id="@+id/tvAgencyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OCEANX"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/primary_blue"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/tvAgencySub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AGENCY"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:textColor="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/tvAgencyName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 3. Delivery Promise Text -->
    <TextView
        android:id="@+id/tvSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Groceries delivered\nin 10 minutes"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/text_black"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/ivLoginHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llPhoneInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91"
            android:textStyle="bold"
            android:textSize="19sp"
            android:textColor="@color/text_black"
            android:layout_marginEnd="12dp"/>


        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Enter mobile number"
            android:inputType="phone"
            android:maxLength="10"
            android:textSize="19sp"
            android:textColor="@color/text_black"/>

    </LinearLayout>

    <!-- 5. Send OTP Button -->
    <Button
        android:id="@+id/btnSendOtp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Send OTP"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_blue"
        android:textColor="@color/white"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/llPhoneInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- 6. Footer Legal Text -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="By continuing, you agree to our\nTerms of Service &amp; Privacy Policy"
        android:textSize="18sp"
        android:textStyle="bold"

        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />




</androidx.constraintlayout.widget.ConstraintLayout>